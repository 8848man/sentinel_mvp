# Runtime environment: development | testing | production
APP_ENV=development

# ── Database ──────────────────────────────────────────────────────────────────
# Development / Testing — SQLite (no external DB required)
DATABASE_URL=sqlite+aiosqlite:///./sentinel_dev.db

# Production — Supabase PostgreSQL (set via Cloud Run secret injection)
# DATABASE_URL=postgresql+asyncpg://postgres:<password>@db.<project>.supabase.co:5432/postgres

# ── Auth ──────────────────────────────────────────────────────────────────────
# Development: use any string; JWTs must be signed with this secret
# Production: must match the Supabase project JWT secret exactly
SUPABASE_JWT_SECRET=dev-insecure-secret-change-in-production

# ── Gemini AI ─────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash
GEMINI_TIMEOUT_SECONDS=15

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ── Feature Flags ─────────────────────────────────────────────────────────────
# Development/local: true  → POST /api/v1/auth/register accepts email+password
#                           without any verification-code step.
# Production:        false → the endpoint returns 403; full Supabase OTP flow applies.
SKIP_EMAIL_VERIFICATION=true
