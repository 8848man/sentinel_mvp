# ─────────────────────────────────────────────────────────────────────────────
# Sentinel API — environment variable reference
#
# Copy this file to .env for local development.
# In production (Cloud Run) all values are injected via:
#   • Non-sensitive config  → Cloud Run --set-env-vars
#   • Secrets               → Google Secret Manager via Cloud Run --set-secrets
#
# NEVER commit a .env file with real secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
# production | development

# ── Database ──────────────────────────────────────────────────────────────────
# Development / Testing — SQLite (no external DB required)
DATABASE_URL=sqlite+aiosqlite:///./sentinel_dev.db

# Production — Supabase Transaction Pooler (port 6543) for runtime queries.
# This is the async runtime URL.  asyncpg scheme required.
# DATABASE_URL=postgresql+asyncpg://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# ── Alembic / Migrations ──────────────────────────────────────────────────────
# Direct connection (port 5432) for DDL migrations — NEVER the pooler port 6543.
# Must use plain postgresql:// (psycopg2/sync) — NOT postgresql+asyncpg://.
# Found in: Supabase Dashboard → Project Settings → Database → Connection string (URI)
# MIGRATION_DATABASE_URL=postgresql://postgres:<password>@db.<ref>.supabase.co:5432/postgres

# ── Supabase ──────────────────────────────────────────────────────────────────
# Project URL — used to fetch the JWKS endpoint for JWT verification.
# Found in: Supabase Dashboard → Project Settings → API → Project URL
# Format: https://<ref>.supabase.co  (no trailing slash)
SUPABASE_URL=https://<ref>.supabase.co

# ── Gemini AI ─────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash
GEMINI_TIMEOUT_SECONDS=15

# Dedicated timeout for OCR image-to-text extraction only (extract_log_from_image).
# Multimodal OCR requests on dense screenshots routinely take 20-30s, well beyond
# GEMINI_TIMEOUT_SECONDS above (which covers the fast text-only metadata/analysis
# calls). Does not affect AI Log Cleanup or any other Gemini call.
OCR_TIMEOUT_SECONDS=60

# Timeout for background incident analysis (execute_analysis worker).
# Larger than GEMINI_TIMEOUT_SECONDS — complex logs take longer to process.
ANALYSIS_TIMEOUT_SECONDS=120

# Maximum characters sent to Gemini for analysis. Logs exceeding this are
# truncated using a head+tail strategy before the API call. Full log is always
# stored in the DB regardless of truncation.
MAX_ANALYSIS_INPUT_CHARS=30000

# ── CORS ──────────────────────────────────────────────────────────────────────
# Development: include Flutter web dev server ports
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]
# Production example:
# ALLOWED_ORIGINS=["https://your-app.web.app","https://your-custom-domain.com"]

# ── Feature Flags ─────────────────────────────────────────────────────────────
# true  → POST /api/v1/auth/register available (dev convenience)
# false → endpoint returns 403; Supabase handles all user creation in production
SKIP_EMAIL_VERIFICATION=true

# ── Development authentication — DO NOT set in production ─────────────────────
# When ENABLE_DEV_AUTH=True, POST /api/v1/dev/token issues 24-hour HS256 JWTs
# for registered dev users. Must NEVER appear in Cloud Run config or Secret Manager.
# ENABLE_DEV_AUTH=True
# DEV_JWT_SECRET=dev-insecure-local-secret-change-me

# ── Server (production only) ──────────────────────────────────────────────────
# Number of Gunicorn workers per container instance.
# Cloud Run scales horizontally — keep this low (1–2) and let Cloud Run
# add more instances instead of adding workers within a single container.
# WEB_CONCURRENCY=1
